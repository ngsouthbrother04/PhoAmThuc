DATABASE_URL="postgresql://admin:password123@localhost:5433/pho_am_thuc?schema=public"
PAYMENT_CALLBACK_SECRET="replace-with-real-secret"
PAYMENT_CALLBACK_MAX_AGE_SECONDS=300

# TTS runtime controls
# Queue mode: set REDIS_URL to enable BullMQ mode, leave empty for in-memory fallback
REDIS_URL=""
TTS_WORKER_CONCURRENCY=5
TTS_SUPPORTED_LANGUAGES="vi,en,ko,ja,fr,de,es,pt,ru,zh,th,id,hi,ar,tr"
TTS_PROVIDER="piper"

# Audio storage provider (fixed): local
TTS_STORAGE_PROVIDER="local"

# Local provider settings
TTS_LOCAL_AUDIO_DIR="./public/audio"
TTS_PUBLIC_BASE_URL="/audio"

# Piper settings
# If PIPER_MODEL_MAP is empty, models are resolved from PIPER_MODEL_DIR/<lang>.onnx
PIPER_BIN="piper"
PIPER_MODEL_DIR="./piper/models"
PIPER_MODEL_MAP=""

# Google Cloud TTS settings
# Use one of these credential methods:
# 1) GOOGLE_APPLICATION_CREDENTIALS points to service account JSON file path
# 2) GOOGLE_TTS_CREDENTIALS_JSON contains whole service account JSON string
# 3) GOOGLE_TRANSLATE_CREDENTIALS_JSON (optional) overrides translate credentials
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_TTS_CREDENTIALS_JSON=""
GOOGLE_TRANSLATE_CREDENTIALS_JSON=""
# Optional: map language to specific voice name, e.g. {"en":"en-US-Neural2-C","vi":"vi-VN-Standard-A"}
GOOGLE_TTS_VOICE_MAP=""
GOOGLE_TTS_SPEAKING_RATE=1
GOOGLE_TTS_PITCH=0
POI_TRANSLATION_STRICT_MODE="false"

# Cloudinary settings for image upload (POI + Tour)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_POI_FOLDER="phoamthuc/pois"
CLOUDINARY_TOUR_FOLDER="phoamthuc/tours"
CLOUDINARY_MAX_IMAGE_BYTES=5242880
CLOUDINARY_IMAGE_MAX_WIDTH=1600

# Startup strict mode: fail fast when TTS config invalid
TTS_STRICT_CONFIG="false"

